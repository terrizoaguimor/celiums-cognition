# Celiums Cognition is an OpenClaw *plugin*. The `openclaw` host (and its native
# deps: sharp, koffi, protobufjs, …) is provided at runtime by ClawHub / the
# user's OpenClaw install, NOT built in this dev tree — we only consume its
# TypeScript types. Disable dependency lifecycle scripts entirely so installs
# are deterministic, fast, and exit-0 in CI (no interactive build approval).
ignore-scripts=true
auto-install-peers=false
strict-peer-dependencies=false
