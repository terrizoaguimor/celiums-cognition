# dependencies
node_modules/
.pnpm-store/

# build output
dist/
*.tsbuildinfo

# test / coverage
coverage/
.vitest/

# corpus is downloaded as a release asset, never tracked
/corpus/*
!/corpus/.gitkeep

# local data written by the gateway during dev
.openclaw/

# env / secrets — NEVER track
.env
.env.*
!.env.example

# logs / misc
*.log
pnpm-debug.log*
.DS_Store
.turbo/

# local-only backups (git bundles, dumps) — never tracked
backups/

# `npm pack` artifacts — built locally for inspection / smoke installs
# before publish. Never committed; the tarball is produced from current
# dist/ each time.
*.tgz

# Agent control plane — operator-specific notes (paths, identities,
# session pipelines). Kept on disk per-machine, never tracked.
CLAUDE.md
AGENTS.md
.agents/
