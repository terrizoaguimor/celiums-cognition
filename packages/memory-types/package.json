{
  "name": "@celiums/memory-types",
  "version": "2.0.0",
  "private": true,
  "description": "TypeScript types for the vendored Celiums Memory engine (vendored sibling — never published; resolves via workspace:* exactly as upstream)",
  "license": "Apache-2.0",
  "author": "Celiums Solutions LLC",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "echo '(memory-types is type-only — no tests)'",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
