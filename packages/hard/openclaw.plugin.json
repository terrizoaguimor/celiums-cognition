{
  "id": "celiums-cognition",
  "kind": "memory",
  "name": "Celiums Cognition",
  "description": "Persistent emotional memory for OpenClaw — ethics, journal, PAD-circadian, hybrid retrieval (Hard: Postgres + Qdrant + Valkey).",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "absorb",
      "atlas_ask",
      "atlas_chat",
      "atlas_classify",
      "atlas_list_models",
      "atlas_recommend",
      "bloom",
      "compact_checkpoint",
      "construct",
      "cultivate",
      "decompose",
      "ethics_audit",
      "ethics_lookup",
      "ethics_trace",
      "forage",
      "journal_arc",
      "journal_dialogue",
      "journal_introspect",
      "journal_recall",
      "journal_recall_secure",
      "journal_redact_secure",
      "journal_supersede",
      "journal_verify_chain",
      "journal_write",
      "journal_write_secure",
      "map_network",
      "memory_bulk_delete_secure",
      "memory_delete_secure",
      "memory_recall_secure",
      "memory_remember_secure",
      "memory_update_secure",
      "pollinate",
      "profile_publish_secure",
      "recall",
      "remember",
      "research_export",
      "research_finding_add",
      "research_gap_add",
      "research_project_continue",
      "research_project_create",
      "research_project_list",
      "research_search",
      "research_source_add",
      "research_source_delete",
      "research_source_list",
      "research_synthesize",
      "sense",
      "synthesize",
      "tenant_delete_secure",
      "tenant_export_secure",
      "turn_after",
      "turn_context",
      "web_search",
      "write_character_create",
      "write_continuity_check",
      "write_export",
      "write_project_create",
      "write_project_get",
      "write_project_list",
      "write_scene_create",
      "write_scene_update"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "agentId": {
        "type": "string",
        "default": "main"
      },
      "userId": {
        "type": "string"
      },
      "ethics": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "strictMode": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "journal": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "autoRecall": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "trivialSkipRegex": {
            "type": "string",
            "default": "^(ok|si|no|gracias)[\\s.!?]*$"
          }
        }
      },
      "autoCapture": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "minImportance": {
            "type": "number",
            "default": 0.3
          }
        }
      },
      "dreaming": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "exposedTools": {
        "type": "string",
        "enum": [
          "curated",
          "all"
        ],
        "default": "curated"
      },
      "database": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "endpoint": {
            "type": "string",
            "default": "localhost:5432"
          }
        }
      }
    }
  },
  "uiHints": {
    "userId": {
      "label": "User ID",
      "placeholder": "e.g. mario"
    },
    "ethics.strictMode": {
      "label": "Strict ethics mode",
      "advanced": true
    },
    "exposedTools": {
      "label": "Tool surface",
      "help": "curated = 8 essential tools, all = 50+ tools"
    },
    "database.endpoint": {
      "label": "Postgres endpoint",
      "placeholder": "localhost:5432"
    }
  },
