{
  "name": "@celiumsai/cognition",
  "version": "0.1.1",
  "type": "module",
  "description": "Persistent emotional memory for OpenClaw agents — ethics gate, SHA-chained journal, PAD-circadian limbic, hybrid retrieval (Postgres + Qdrant + Valkey + OpenSearch).",
  "license": "Apache-2.0",
  "author": "Celiums Solutions LLC",
  "homepage": "https://github.com/terrizoaguimor/celiums-cognition#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terrizoaguimor/celiums-cognition.git",
    "directory": "packages/hard"
  },
  "bugs": {
    "url": "https://github.com/terrizoaguimor/celiums-cognition/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "clawhub",
    "memory",
    "ethics",
    "ai-agents",
    "vector-search",
    "embeddings",
    "postgres",
    "qdrant",
    "opensearch",
    "celiums"
  ],
  "main": "./dist/index.js",
  "bin": {
    "celiums-cognition": "./dist/setup.js"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.18",
      "minGatewayVersion": "2026.5.18"
    },
    "build": {
      "openclawVersion": "2026.5.19",
      "pluginSdkVersion": "2026.5.19"
    }
  },
  "scripts": {
    "build": "tsup && rm -rf dist/compose dist/migrations dist/ui && cp -R src/compose dist/compose && cp -R ../engine/scripts/migrations dist/migrations && (cd ui && npm install --no-audit --no-fund --silent && npm run build) && cp -R ui/dist dist/ui",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo '(hard E2E smoke is run against a live OpenClaw — see docs)'",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "node scripts/prepack.mjs",
    "postpack": "node scripts/postpack.mjs"
  },
  "dependencies": {
    "@celiums/types": "^0.1.1",
    "@langchain/anthropic": "^1.3.28",
    "@langchain/aws": "^1.3.5",
    "@langchain/core": "^1.1.44",
    "@langchain/deepseek": "^1.0.25",
    "@langchain/google-genai": "^2.1.28",
    "@langchain/google-vertexai": "^2.1.28",
    "@langchain/mistralai": "^1.0.8",
    "@langchain/openai": "^1.4.5",
    "@langchain/xai": "^1.3.17",
    "@qdrant/js-client-rest": "^1.17.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "cohere-ai": "^8.0.0",
    "ioredis": "^5.10.1",
    "jose": "^5.10.0",
    "maxmind": "^4.3.29",
    "ollama": "^0.5.18",
    "pg": "^8.20.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.18"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@celiumsai/cognition-shared": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
