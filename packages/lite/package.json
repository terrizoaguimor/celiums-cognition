{
  "name": "@celiumsai/cognition-lite",
  "version": "0.1.0",
  "type": "module",
  "description": "Persistent emotional memory for OpenClaw agents — Lite edition (embedded pglite + pgvector, zero external infra)",
  "license": "Apache-2.0",
  "author": "Celiums Solutions LLC",
  "homepage": "https://github.com/celiumssolutions/celiums-cognition",
  "keywords": ["openclaw", "openclaw-plugin", "memory", "celiums", "clawhub", "embedded"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.18"
    },
    "build": {
      "openclawVersion": "2026.5.19"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo '(no lite tests yet — arrive in Fase 4)'",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@celiumsai/cognition-shared": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.18"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  }
}
